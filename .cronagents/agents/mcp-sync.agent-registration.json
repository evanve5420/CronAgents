{
  "$schema": "../../cronagents-agent.schema.json",
  "name": "MCP Config Sync",
  "agent": "mcp-sync",
  "prompt": "Synchronize the three Windows MCP configuration files now and summarize exactly what changed.",
  "schedule": { "type": "weekly", "day": "monday", "time": "09:00" },
  "timeout": "15m",
  "retryCount": 1,
  "denyTools": [
    "shell(git:*)",
    "shell(rm)",
    "shell(del)",
    "shell(rmdir)",
    "shell(Remove-Item)",
    "shell(taskkill)",
    "shell(Stop-Process)",
    "shell(shutdown)",
    "shell(Restart-Computer)"
  ],
  "extraCliFlags": [
    "--allow-all-paths"
  ]
}
